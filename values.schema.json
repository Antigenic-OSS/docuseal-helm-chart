{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "tag", "pullPolicy"]
    },
    "database": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "url": { "type": "string" },
        "existingSecret": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "secret": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "create": { "type": "boolean" },
        "data": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "properties": {
            "DATABASE_URL": { "type": "string" },
            "SECRET_KEY_BASE": { "type": "string" }
          }
        }
      },
      "required": ["create"]
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "secretReloader": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "general": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "forceSsl": { "type": "boolean" },
        "host": { "type": "string" }
      }
    },
    "smtp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "address": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "domain": { "type": "string" },
        "authentication": { "type": "string", "enum": ["plain", "login"] },
        "from": { "type": "string" },
        "enableStarttls": { "type": "boolean" },
        "sslVerify": { "type": "boolean" },
        "username": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "password": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "s3": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "region": { "type": "string" },
        "attachmentsBucket": { "type": "string" },
        "accessKeyId": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "secretAccessKey": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "gcs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "project": { "type": "string" },
        "bucket": { "type": "string" },
        "credentials": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "azure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "storageAccountName": { "type": "string" },
        "container": { "type": "string" },
        "storageAccessKey": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "value": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "name": { "type": "string" },
                "key": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "externalTrafficPolicy": {
          "type": "string",
          "enum": ["Local", "Cluster"]
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": ["integer", "string"] }
      },
      "required": ["type", "port", "targetPort"]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": {
                      "type": "string",
                      "enum": ["Prefix", "Exact", "ImplementationSpecific"]
                    }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": {
          "type": "object",
          "additionalProperties": true
        },
        "hostnames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parentRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string", "minLength": 1 }
            },
            "required": ["name"]
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessModes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "size": { "type": "string", "minLength": 1 },
        "mountPath": { "type": "string", "minLength": 1 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowSameNamespace": { "type": "boolean" },
            "allowInternet": { "type": "boolean" },
            "internetCidrs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "additionalFrom": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        },
        "egress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowDns": { "type": "boolean" },
            "dnsTo": {
              "type": "array",
              "items": { "type": "object" }
            },
            "allowInternet": { "type": "boolean" },
            "internetCidrs": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "additionalTo": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      }
    },
    "testConnection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        }
      },
      "required": ["enabled", "image"]
    }
  },
  "allOf": [
    {
      "not": {
        "allOf": [
          {
            "properties": {
              "ingress": {
                "properties": {
                  "enabled": { "const": true }
                },
                "required": ["enabled"]
              }
            }
          },
          {
            "properties": {
              "httpRoute": {
                "properties": {
                  "enabled": { "const": true }
                },
                "required": ["enabled"]
              }
            }
          }
        ]
      }
    }
  ]
}
